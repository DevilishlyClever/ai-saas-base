# =============================================================================
# AI SaaS Base — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# -----------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Stripe — https://dashboard.stripe.com/apikeys
# Use test mode keys (sk_test_...) for local development
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
STRIPE_PRO_PRICE_ID=price_your-price-id-here

# Public Stripe key for client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# -----------------------------------------------------------------------------
# AI / Vercel AI Gateway
# Run `vercel env pull .env.local` to get VERCEL_OIDC_TOKEN automatically.
# Or set a manual API key for non-Vercel environments:
# -----------------------------------------------------------------------------
# AI_GATEWAY_API_KEY=your-ai-gateway-api-key

# Fallback: direct Anthropic key (if not using AI Gateway)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
